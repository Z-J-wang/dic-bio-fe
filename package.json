{
  "name": "smart-nuxt-template",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "description": "深圳医学科学院-国家基因库数据库开发小组-前端 nuxt 模板项目。",
  "author": "wangzhijie <wangzhijie@smart.org.cn>",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:mock": "nuxt dev --dotenv .env.mock",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"app/**/*.{vue,css,less,html,xml}\"",
    "lint": "pnpm run lint:eslint && pnpm run lint:stylelint",
    "lint:fix": "pnpm run lint:eslint --fix && pnpm run lint:stylelint --fix",
    "type-check": "npx nuxt typecheck"
  },
  "dependencies": {
    "@internationalized/date": "3.10.0",
    "@nuxt/eslint": "1.11.0",
    "@nuxt/icon": "2.1.0",
    "@nuxt/test-utils": "3.20.1",
    "@nuxt/ui": "4.2.1",
    "@nuxtjs/i18n": "10.2.1",
    "@pinia/nuxt": "0.11.3",
    "@regle/core": "1.11.0",
    "@regle/nuxt": "1.11.0",
    "@regle/rules": "1.11.0",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "nuxt": "4.2.1",
    "pinia": "3.0.4",
    "tailwindcss": "4.1.17",
    "vue": "3.5.25",
    "vue-i18n": "11.2.2",
    "vue-router": "4.6.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.6.1",
    "@types/mockjs": "^1.0.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "less": "4.4.2",
    "mockjs": "^1.1.0",
    "postcss": "8.5.6",
    "postcss-html": "1.8.0",
    "prettier": "3.7.1",
    "stylelint": "16.26.0",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-standard": "39.0.1",
    "stylelint-config-standard-less": "3.0.1",
    "stylelint-config-standard-vue": "1.0.0",
    "stylelint-order": "7.0.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "5.9.3",
    "vue-tsc": "3.1.5"
  },
  "engines": {
    "node": "^22.21.1",
    "pnpm": "^10.23.0"
  }
}
