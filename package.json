{
  "name": "smart-nuxt-template",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "description": "深圳医学科学院-国家基因库数据库开发小组-前端 nuxt 模板项目。",
  "author": "wangzhijie <wangzhijie@smart.org.cn>",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:local": "nuxt dev --dotenv .env.local",
    "dev:mock": "nuxt dev --dotenv .env.mock",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"app/**/*.{vue,css,less,html,xml}\"",
    "lint": "pnpm run lint:eslint && pnpm run lint:stylelint",
    "lint:fix": "pnpm run lint:eslint --fix && pnpm run lint:stylelint --fix",
    "type-check": "npx nuxt typecheck"
  },
  "dependencies": {
    "@internationalized/date": "3.10.1",
    "@nuxt/eslint": "1.12.1",
    "@nuxt/icon": "2.2.0",
    "@nuxt/test-utils": "3.23.0",
    "@nuxt/ui": "4.3.0",
    "@nuxtjs/i18n": "10.2.1",
    "@pinia/nuxt": "0.11.3",
    "@regle/core": "1.16.2",
    "@regle/nuxt": "1.16.2",
    "@regle/rules": "1.16.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "github-markdown-css": "^5.8.1",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "lenis": "^1.3.17",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "nuxt": "4.2.2",
    "pinia": "3.0.4",
    "reka-ui": "^2.7.0",
    "tailwindcss": "4.1.18",
    "vue": "3.5.26",
    "vue-i18n": "11.2.8",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/mockjs": "^1.0.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.8",
    "less": "4.5.1",
    "mockjs": "^1.1.0",
    "postcss": "8.5.6",
    "postcss-html": "1.8.0",
    "prettier": "3.7.4",
    "stylelint": "16.26.1",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-standard": "39.0.1",
    "stylelint-config-standard-less": "4.0.1",
    "stylelint-config-standard-vue": "1.0.0",
    "stylelint-order": "7.0.1",
    "stylelint-prettier": "5.0.3",
    "typescript": "5.9.3",
    "vue-tsc": "3.2.2"
  },
  "engines": {
    "node": "^22.21.1",
    "pnpm": "^10.23.0"
  }
}
